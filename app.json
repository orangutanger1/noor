{
  "expo": {
    "name": "Noor: Prayer Times & Quran",
    "slug": "noor-islamic-companion-",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./logo.png",
    "scheme": "noor-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/228d6060-5f92-4422-ba25-bcd5985a6193"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#004D40"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noor.prayer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to calculate accurate prayer times and Qibla direction.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.noor.prayer",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://noor.app/"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Your location is used to calculate accurate prayer times and Qibla direction."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://noor.app/"
      },
      "eas": {
        "projectId": "228d6060-5f92-4422-ba25-bcd5985a6193"
      }
    },
    "owner": "mayfield"
  }
}
